# ── TheWatcher environment ─────────────────────────────────────────────
# Copy this file to `.env` (in the backend/ folder or project root) and fill in.
# Only CEREBRAS_API_KEY is required to start. Everything else degrades gracefully.

# ---- Cerebras (Gemma) : REQUIRED -------------------------------------
# OpenAI-compatible Chat Completions endpoint.
CEREBRAS_API_KEY=
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
CEREBRAS_MODEL=gemma-4-31b

# ---- Google Gemini : OPTIONAL (needed for the side-by-side comparison) -
# Without this key the Gemini column shows a "mock" result so the UI still works.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ---- 511NY (NYC cameras + alerts) : OPTIONAL -------------------------
# Without this key the app uses bundled sample camera data (backend/app/data).
NY511_API_KEY=

# ---- NYC Open Data (Socrata) : OPTIONAL ------------------------------
SOCRATA_APP_TOKEN=

# ---- Map tiles : OPTIONAL --------------------------------------------
# Frontend uses free OpenStreetMap tiles by default. Set a Geoapify key to switch.
VITE_GEOAPIFY_KEY=

# ---- Backend server ---------------------------------------------------
WATCHER_HOST=127.0.0.1
WATCHER_PORT=8000
# Comma-separated origins allowed to call the API (the Vite dev server).
WATCHER_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
